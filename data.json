{
  "queryPresets": [
    {
      "id": "preset-today",
      "name": "Today",
      "builtin": true,
      "hidden": false,
      "filters": {
        "status": [
          "todo"
        ]
      },
      "view": {
        "layout": {
          "type": "list",
          "sections": [
            {
              "id": "overdue",
              "title": "Overdue",
              "when": {
                "status": "all",
                "time": {
                  "deadline": "overdue"
                }
              },
              "orderBy": [
                "deadline_asc"
              ],
              "limit": 3
            },
            {
              "id": "today",
              "title": "Today",
              "when": {
                "status": "all",
                "time": {
                  "scheduled": "today"
                }
              },
              "limit": 3
            },
            {
              "id": "unscheduled-rec",
              "title": "Unscheduled",
              "when": {
                "status": "all",
                "time": {
                  "scheduled": "unscheduled",
                  "deadline": "unscheduled"
                }
              },
              "orderBy": [
                "created_desc"
              ],
              "limit": 3
            }
          ]
        }
      }
    },
    {
      "id": "preset-week",
      "name": "Week",
      "builtin": true,
      "hidden": false,
      "filters": {
        "status": [
          "todo"
        ]
      },
      "view": {
        "layout": {
          "dir": "col",
          "children": [
            {
              "type": "week"
            },
            {
              "dir": "row",
              "children": [
                {
                  "id": "unscheduled-tray",
                  "title": "Unscheduled",
                  "onDrop": {
                    "clearScheduled": true
                  },
                  "type": "grid",
                  "when": {
                    "status": "all",
                    "time": {
                      "scheduled": "unscheduled"
                    }
                  }
                },
                {
                  "title": "Drop",
                  "onDrop": {
                    "setStatus": "dropped"
                  },
                  "type": "drop"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "id": "preset-month",
      "name": "Month",
      "builtin": true,
      "hidden": false,
      "filters": {
        "status": [
          "todo"
        ]
      },
      "view": {
        "layout": {
          "dir": "col",
          "children": [
            {
              "type": "month"
            },
            {
              "dir": "row",
              "children": [
                {
                  "id": "unscheduled-tray",
                  "title": "Unscheduled",
                  "onDrop": {
                    "clearScheduled": true
                  },
                  "type": "grid",
                  "when": {
                    "status": "all",
                    "time": {
                      "scheduled": "unscheduled"
                    }
                  }
                },
                {
                  "title": "Drop",
                  "onDrop": {
                    "setStatus": "dropped"
                  },
                  "type": "drop"
                }
              ]
            }
          ]
        }
      }
    },
