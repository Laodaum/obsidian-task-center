{
  "id": "preset-month",
  "name": "Month",
  "builtin": true,
  "hidden": false,
  "filters": {
    "status": ["todo"]
  },
  "view": {
    "layout": {
      "dir": "col",
      "children": [
        { "type": "month" },
        {
          "dir": "row",
          "children": [
            {
              "type": "grid",
              "id": "unscheduled-tray",
              "title": "Unscheduled",
              "when": { "time": { "scheduled": "unscheduled" } },
              "onDrop": { "clearScheduled": true }
            },
            {
              "type": "drop",
              "title": "Drop",
              "onDrop": { "setStatus": "dropped" }
            }
          ]
        }
      ]
    }
  }
}
